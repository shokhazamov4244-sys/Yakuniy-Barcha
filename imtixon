<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Imtihon Test Tizimi</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <style>
        :root {
            --bg-color: #f4f6f9;
            --card-bg: #ffffff;
            --text-color: #333333;
            --primary-color: #2481cc;
            --success-color: #2ec4b6;
            --danger-color: #e71d36;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        body { background-color: var(--bg-color); color: var(--text-color); padding: 15px; display: flex; justify-content: center; }
        .container { width: 100%; max-width: 500px; background: var(--card-bg); padding: 20px; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); }
        h2 { text-align: center; margin-bottom: 20px; color: var(--primary-color); font-size: 22px; }
        .btn { display: block; width: 100%; padding: 12px 15px; background: var(--primary-color); color: white; border: none; border-radius: 8px; font-size: 16px; font-weight: bold; cursor: pointer; margin-bottom: 12px; transition: background 0.2s; text-align: left; }
        .btn:active { background: #1a65a4; }
        .input-group { margin-bottom: 20px; }
        .input-group label { display: block; margin-bottom: 8px; font-weight: 600; }
        .input-group input { width: 100%; padding: 12px; border: 1px solid #ccc; border-radius: 8px; font-size: 16px; }
        .hidden { display: none; }
        .progress-bar { width: 100%; background: #eee; height: 8px; border-radius: 4px; margin-bottom: 15px; overflow: hidden; }
        .progress { height: 100%; background: var(--success-color); width: 0%; transition: width 0.3s; }
        .question-title { font-size: 18px; font-weight: 600; margin-bottom: 20px; line-height: 1.4; }
        .option-btn { background: #f0f4f8; color: var(--text-color); font-weight: normal; border: 1px solid #dcdcdc; }
        .option-btn:active { background: #d0e1f9; }
        .result-card { text-align: center; }
        .result-score { font-size: 48px; font-weight: bold; color: var(--primary-color); margin: 15px 0; }
        .status-text { font-size: 18px; font-weight: 600; margin-bottom: 20px; }
    </style>
</head>
<body>

<div class="container">
    <div id="subject-screen">
        <h2>Imtihon Fanlari</h2>
        <p style="text-align:center; margin-bottom:20px; color:#666;">Iltimos, test topshiradigan fanni tanlang:</p>
        <button class="btn" onclick="selectSubject('UnityHub')">📘 UnityHub</button>
        <button class="btn" onclick="selectSubject('Hisoblash matematikasi')">📐 Hisoblash matematikasi</button>
        <button class="btn" onclick="selectSubject('Hisoblash asoslari')">💻 Hisoblash asoslari</button>
        <button class="btn" onclick="selectSubject('Internet dasturiy taʼminoti')">🌐 Internet dasturiy taʼminoti</button>
    </div>

    <div id="auth-screen" class="hidden">
        <h2>Ro‘yxatdan o‘tish</h2>
        <div class="input-group">
            <label for="username">Ism va Familiyangiz:</label>
            <input type="text" id="username" placeholder="Masalan: Eshmatov Toshmat">
        </div>
        <button class="btn" style="text-align:center;" onclick="startTest()">Testni boshlash 🚀</button>
    </div>

    <div id="quiz-screen" class="hidden">
        <div class="progress-bar"><div id="progress" class="progress"></div></div>
        <div id="quiz-info" style="font-size:14px; color:#666; margin-bottom:10px;"></div>
        <div id="question-text" class="question-title"></div>
        <div id="options-container"></div>
    </div>

    <div id="result-screen" class="hidden" class="result-card">
        <h2>Test Yakunlandi!</h2>
        <div id="result-name" style="font-weight:bold; font-size:18px;"></div>
        <div id="result-subject" style="color:#666; margin-top:5px;"></div>
        <div id="score" class="result-score">0%</div>
        <div id="details" class="status-text"></div>
        <button class="btn" style="text-align:center; background:var(--success-color);" onclick="closeWebApp()">Yopish (Telegramga qaytish)</button>
    </div>
</div>

<script>
    // Telegram Web App obyekti integratsiyasi
    const tg = window.Telegram?.WebApp;
    if (tg) tg.expand(); // Oynani to'liq ochish

    // SAVOLLAR BAZASI
    const quizData = {
        "UnityHub": [
            { q: "Rigidbody komponentasida “Interpolate” parametri qanday vazifani bajaradi?", opts: ["Kolliziyani o‘chirish uchun", "Fizika hisob-kitoblarini tezlashtiradi", "Frame’lar orasida obyekt harakatini silliqlashtiradi", "Obyektni gravitatsiyadan himoya qiladi"], c: "Frame’lar orasida obyekt harakatini silliqlashtiradi" },
            { q: "Quyidagi komponentalardan qaysi biri obyektni sahnada ko‘rinadigan qiladi?", opts: ["Rigidbody", "Collider", "Mesh Renderer", "Transform"], c: "Mesh Renderer" },
            { q: "Box Collider va Box Collider 2D orasidagi asosiy farq nimada?", opts: ["Box Collider faqat statik obyektlar uchun", "Box Collider 2D faqat 2D fizik dvijok bilan ishlaydi", "UI elementlar uchun", "Gravitatsiyani qo‘llab-quvvatlamaydi"], c: "Box Collider 2D faqat 2D fizik dvijok bilan ishlaydi" }
        ],
        "Hisoblash matematikasi": [
            { q: "Interpolyatsion ko'phadlar nima uchun ishlatiladi?", opts: ["Funksiyani taqribiy tiklash uchun", "Tenglamani aniq yechish uchun", "Grafik chizish uchun", "Hosilani hisoblash uchun"], c: "Funksiyani taqribiy tiklash uchun" },
            { q: "Nyuton usuli qanday tenglamalarni yechishda qo'llaniladi?", opts: ["Chiziqli bo'lmagan tenglamalarni", "Faqat kvadrat tenglamalarni", "Matrisalarni", "Differensial tenglamalarni"], c: "Chiziqli bo'lmagan tenglamalarni" }
        ],
        "Hisoblash asoslari": [
            { q: "Sirtqi ta'limda hisoblash tizimlarining asosiy vazifasi nima?", opts: ["Ma'lumotlarni qayta ishlashni avtomatlashtirish", "Faqat o'yinlar o'ynash", "Matn muharrirlari yaratish", "Internet tezligini oshirish"], c: "Ma'lumotlarni qayta ishlashni avtomatlashtirish" }
        ],
        "Internet dasturiy taʼminoti": [
            { q: "Mijoz-server (Client-Server) arxitekturasida mijoz vazifasini nima bajaradi?", opts: ["Brauzer (Browser)", "Ma'lumotlar bazasi", "Xosting provayder", "Kabel tarmoqlari"], c: "Brauzer (Browser)" },
            { q: "HTTP nima?", opts: ["Gipermatnli uzatish protokoli", "Dasturlash tili", "Ma'lumotlar bazasi turi", "Grafik muharrir"], c: "Gipermatnli uzatish protokoli" }
        ]
    };

    let chosenSubject = "";
    let userName = "";
    let currentQuestions = [];
    let currentIndex = 0;
    let correctCount = 0;

    function selectSubject(subject) {
        chosenSubject = subject;
        document.getElementById('subject-screen').classList.add('hidden');
        document.getElementById('auth-screen').classList.remove('hidden');
    }

    function startTest() {
        userName = document.getElementById('username').value.trim();
        if (!userName) {
            alert("Iltimos, ism va familiyangizni kiriting!");
            return;
        }

        // Fanga tegishli savollarni yuklash va aralashtirish (Random 20 ta)
        let allQ = quizData[chosenSubject] || [];
        if(allQ.length === 0) {
            alert("Bu fanga hali savollar yuklanmagan!");
            return;
        }
        
        currentQuestions = [...allQ].sort(() => 0.5 - Math.random()).slice(0, 20);
        currentIndex = 0;
        correctCount = 0;

        document.getElementById('auth-screen').classList.add('hidden');
        document.getElementById('quiz-screen').classList.remove('hidden');
        
        showQuestion();
    }

    function showQuestion() {
        if (currentIndex >= currentQuestions.length) {
            finishQuiz();
            return;
        }

        let qObj = currentQuestions[currentIndex];
        
        // Progress yangilash
        let progressPercent = (currentIndex / currentQuestions.length) * 100;
        document.getElementById('progress').style.width = progressPercent + "%";
        document.getElementById('quiz-info').innerText = `Fan: ${chosenSubject} | Savol: ${currentIndex + 1}/${currentQuestions.length}`;
        
        document.getElementById('question-text').innerText = qObj.q;
        
        // Variantlarni aralashtirib chiqarish
        let options = [...qObj.opts].sort(() => 0.5 - Math.random());
        let optionsContainer = document.getElementById('options-container');
        optionsContainer.innerHTML = "";

        options.forEach(opt => {
            let btn = document.createElement('button');
            btn.className = "btn option-btn";
            btn.innerText = opt;
            btn.onclick = () => checkAnswer(opt, qObj.c);
            optionsContainer.appendChild(btn);
        });
    }

    function checkAnswer(userOpt, correctOpt) {
        if (userOpt === correctOpt) {
            correctCount++;
        }
        currentIndex++;
        showQuestion();
    }

    function finishQuiz() {
        document.getElementById('quiz-screen').classList.add('hidden');
        document.getElementById('result-screen').classList.remove('hidden');

        let total = currentQuestions.length;
        let percent = Math.round((correctCount / total) * 100);

        document.getElementById('result-name').innerText = userName;
        document.getElementById('result-subject').innerText = "Fan: " + chosenSubject;
        document.getElementById('score').innerText = percent + "%";
        document.getElementById('details').innerText = `To'g'ri: ${correctCount} ta | Xato: ${total - correctCount} ta`;

        // Agar Telegram Web App ichida bo'lsa, natijani botga yuborish
        if (tg) {
            let resultData = {
                subject: chosenSubject,
                name: userName,
                correct: correctCount,
                wrong: total - correctCount,
                percentage: percent
            };
            tg.sendData(JSON.stringify(resultData)); // Botning o'ziga ma'lumot qaytaradi
        }
    }

    function closeWebApp() {
        if (tg) {
            tg.close();
        } else {
            alert("Ilova yopildi. (Telegram muhitidan tashqaridasiz)");
        }
    }
</script>
</body>
</html>
